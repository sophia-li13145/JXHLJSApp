<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JXHLJSApp.Pages.Warehouse.DeliveryOrderListPage"
             Title="发货出库单"
             BackgroundColor="#F4F6F9"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*">
        <Border BackgroundColor="#244B88" StrokeThickness="0" Padding="16,22,16,14" HeightRequest="66">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,16,16" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*">
                <Label Text="‹ 返回" TextColor="White" FontSize="15" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Label.GestureRecognizers>
                </Label>
                <Label Grid.Column="1" Text="发货出库单" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalOptions="Center" Margin="0,0,48,0" />
            </Grid>
        </Border>

        <RefreshView Grid.Row="1" x:Name="RefreshContainer" Refreshing="OnRefreshing">
            <CollectionView x:Name="DeliveryOrderList" EmptyView="当前没有发货出库单数据" Margin="20,18,20,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="White" StrokeThickness="0" Padding="20,18" Margin="0,0,0,14">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDeliveryOrderTapped" />
                            </Border.GestureRecognizers>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="12" ColumnSpacing="12">
                                <Label Text="{Binding deliveryNoDisplay}" TextColor="#051B3D" FontSize="19" FontAttributes="Bold" />
                                <Border Grid.Column="1" BackgroundColor="{Binding statusBackgroundColor}" StrokeThickness="0" Padding="10,4" VerticalOptions="Start">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="6" />
                                    </Border.StrokeShape>
                                    <Label Text="{Binding auditStatusDisplay}" TextColor="{Binding statusTextColor}" FontSize="13" FontAttributes="Bold" />
                                </Border>
                                <Label Grid.Row="1" TextColor="#38557C" FontSize="14">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="客户: " />
                                            <Span Text="{Binding customerDisplay}" />
                                            <Span Text=" | 应发: " />
                                            <Span Text="{Binding deliveryQtyDisplay}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
