<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JXHLJSApp.Pages.Warehouse.RawMaterialReceivingListPage"
             Title="采购入库"
             BackgroundColor="#F4F6F9"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*,Auto">
        <Border BackgroundColor="#244B88" StrokeThickness="0" Padding="16,22,16,14" HeightRequest="66">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,16,16" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*">
                <Label Text="‹ 返回" TextColor="White" FontSize="15" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Label.GestureRecognizers>
                </Label>
                <Label Grid.Column="1" Text="采购入库" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalOptions="Center" Margin="0,0,48,0" />
            </Grid>
        </Border>

        <RefreshView Grid.Row="1" x:Name="RefreshContainer" Refreshing="OnRefreshing">
            <CollectionView x:Name="ReceivingList" EmptyView="当前没有采购入库数据" Margin="18,16,18,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="White" StrokeThickness="0" Padding="20,18" Margin="0,0,0,14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="14">
                                <Label Text="{Binding instockNoDisplay}" TextColor="#051B3D" FontSize="19" FontAttributes="Bold" />
                                <Border Grid.Column="1" BackgroundColor="#EAFBF0" StrokeThickness="0" Padding="10,4" VerticalOptions="Start">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="6" />
                                    </Border.StrokeShape>
                                    <Label Text="{Binding statusDisplay}" TextColor="#09913A" FontSize="13" FontAttributes="Bold" />
                                </Border>
                                <Label Grid.Row="1" Grid.ColumnSpan="2" TextColor="#38557C" FontSize="14">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="物料: " />
                                            <Span Text="{Binding materialDisplay}" />
                                            <Span Text=" | " />
                                            <Span Text="{Binding detailCountDisplay}" />
                                            <Span Text=" | " />
                                            <Span Text="{Binding warehouseDisplay}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <Border Grid.Row="2" BackgroundColor="White" StrokeThickness="0" Padding="18,16,18,22">
            <Button Text="+  新增采购入库" BackgroundColor="#1F447E" TextColor="White" FontSize="17" FontAttributes="Bold" CornerRadius="10" HeightRequest="50" Clicked="OnAddClicked" />
        </Border>
    </Grid>
</ContentPage>
