<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JXHLJSApp.Pages.Warehouse.RawMaterialReceivingDetailPage"
             Title="采购入库详情"
             BackgroundColor="#F4F6F9"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*">
        <Border BackgroundColor="#244B88" StrokeThickness="0" Padding="16,22,16,14" HeightRequest="66">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,16,16" /></Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*">
                <Label Text="‹ 返回" TextColor="White" FontSize="15" VerticalOptions="Center">
                    <Label.GestureRecognizers><TapGestureRecognizer Tapped="OnBackTapped" /></Label.GestureRecognizers>
                </Label>
                <Label Grid.Column="1" Text="采购入库详情" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalOptions="Center" Margin="0,0,48,0" />
            </Grid>
        </Border>

        <RefreshView Grid.Row="1" x:Name="RefreshContainer" Refreshing="OnRefreshing">
            <ScrollView>
                <VerticalStackLayout Padding="18,16,18,28" Spacing="16">
                    <Border BackgroundColor="White" StrokeThickness="0" Padding="20,18">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="16">
                            <Label x:Name="InstockNoLabel" Text="--" TextColor="#0A2C61" FontSize="20" FontAttributes="Bold" />
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="16">
                                <Label Text="单据状态" TextColor="#38557C" FontSize="14" />
                                <Label Grid.Column="1" x:Name="StatusLabel" Text="--" TextColor="#04B65B" FontSize="15" FontAttributes="Bold" />
                                <BoxView Grid.Row="1" Grid.ColumnSpan="2" HeightRequest="1" Color="#E7ECF3" />
                                <Label Grid.Row="2" Text="入库时间" TextColor="#38557C" FontSize="14" />
                                <Label Grid.Row="2" Grid.Column="1" x:Name="InstockDateLabel" Text="--" TextColor="#051B3D" FontSize="15" FontAttributes="Bold" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="#E7ECF3" />
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="入库仓库" TextColor="#38557C" FontSize="14" />
                                <Label Grid.Column="1" x:Name="WarehouseLabel" Text="--" TextColor="#051B3D" FontSize="15" FontAttributes="Bold" />
                            </Grid>
                            <BoxView HeightRequest="1" Color="#E7ECF3" />
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="库区" TextColor="#38557C" FontSize="14" />
                                <Label Grid.Column="1" x:Name="LocationLabel" Text="--" TextColor="#051B3D" FontSize="15" FontAttributes="Bold" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Label x:Name="DetailTitleLabel" Text="入库明细 (共 0 件)" TextColor="#051B3D" FontSize="16" FontAttributes="Bold" />
                    <CollectionView x:Name="DetailList" EmptyView="暂无入库明细">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="White" Stroke="#D8E2F0" StrokeThickness="1" Padding="14" Margin="0,0,0,12">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                                    <VerticalStackLayout Spacing="10">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Text="{Binding materialTitle}" TextColor="#0A2C61" FontSize="16" FontAttributes="Bold" />
                                            <Border Grid.Column="1" BackgroundColor="#F2F4F8" StrokeThickness="0" Padding="10,5">
                                                <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                                                <Label Text="{Binding materialTypeDisplay}" TextColor="#20324A" FontSize="13" FontAttributes="Bold" />
                                            </Border>
                                        </Grid>
                                        <BoxView HeightRequest="1" Color="#E7ECF3" />
                                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="7" ColumnSpacing="18">
                                            <Label Text="{Binding materialNameDisplay, StringFormat='物料名称： {0}'}" TextColor="#38557C" FontSize="14" />
                                            <Label Grid.Column="1" Text="{Binding specDisplay, StringFormat='规格： {0}'}" TextColor="#38557C" FontSize="14" />
                                            <Label Grid.Row="1" Text="{Binding furnaceNoDisplay, StringFormat='炉号： {0}'}" TextColor="#38557C" FontSize="14" />
                                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding originDisplay, StringFormat='产地： {0}'}" TextColor="#38557C" FontSize="14" />
                                            <Label Grid.Row="2" IsVisible="{Binding isSemiFinished}" Text="{Binding strengthDisplay, StringFormat='强度： {0}'}" TextColor="#38557C" FontSize="14" />
                                            <Label Grid.Row="2" Grid.Column="1" IsVisible="{Binding isSemiFinished}" Text="{Binding coilCountDisplay, StringFormat='圈数： {0}'}" TextColor="#38557C" FontSize="14" />
                                            <Label Grid.Row="3" IsVisible="{Binding isSemiFinished}" Text="{Binding coilDiameterDisplay, StringFormat='圈径： {0}'}" TextColor="#38557C" FontSize="14" />
                                            <Label Grid.Row="4" Text="{Binding pieceWeightDisplay, StringFormat='件重： {0}'}" TextColor="#00A85A" FontSize="14" FontAttributes="Bold" />
                                            <Label Grid.Row="5" IsVisible="{Binding isSemiFinished}" Text="{Binding countSeqDisplay, StringFormat='件数序号： {0}'}" TextColor="#38557C" FontSize="14" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="附件信息" TextColor="#051B3D" FontSize="16" FontAttributes="Bold" />
                    <Border BackgroundColor="White" StrokeThickness="0" Padding="20">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <CollectionView x:Name="AttachmentList" EmptyView="暂无附件" ItemsLayout="HorizontalList">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#F8FAFD" Stroke="#BFD1E8" Padding="12" Margin="0,0,12,0" WidthRequest="82" HeightRequest="82">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="6">
                                            <Label Text="📄" FontSize="20" HorizontalTextAlignment="Center" />
                                            <Label Text="{Binding attachmentName}" TextColor="#38557C" FontSize="12" LineBreakMode="TailTruncation" HorizontalTextAlignment="Center" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>
    </Grid>
</ContentPage>
