<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JXHLJSApp.Pages.Warehouse.PackagingSubTaskDetailPage"
             Title="执行包装作业"
             BackgroundColor="#F4F6F9"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*,Auto">
        <Border BackgroundColor="#244B88" StrokeThickness="0" Padding="16,22,16,14" HeightRequest="66">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,16,16" /></Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*">
                <Label Text="‹ 返回" TextColor="White" FontSize="15" VerticalOptions="Center"><Label.GestureRecognizers><TapGestureRecognizer Tapped="OnBackTapped" /></Label.GestureRecognizers></Label>
                <Label Grid.Column="1" Text="执行包装作业" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalOptions="Center" Margin="0,0,48,0" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="22,32,22,24" Spacing="16">
                <Button Text="🔍  包装扫码" BackgroundColor="#EEF6FF" TextColor="#0A2E69" BorderColor="#244B88" BorderWidth="1" CornerRadius="10" HeightRequest="50" FontSize="16" FontAttributes="Bold" Clicked="OnScanClicked" />

                <Border BackgroundColor="White" StrokeThickness="0" Padding="20,18">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="包装指令明细" TextColor="#0A2E69" FontSize="17" FontAttributes="Bold" />
                        <BoxView HeightRequest="1" Color="#E1E7F0" />
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto,*" RowSpacing="16" ColumnSpacing="12">
                            <Label Text="任务单号" TextColor="#4B6688" /><Label x:Name="TaskNoLabel" Grid.Column="1" TextColor="#001431" FontAttributes="Bold" />
                            <Label Grid.Column="2" Text="目标物料" TextColor="#4B6688" /><Label x:Name="MaterialLabel" Grid.Column="3" TextColor="#001431" FontAttributes="Bold" />
                            <Label Grid.Row="1" Text="打印模板" TextColor="#4B6688" /><Label x:Name="TemplateLabel" Grid.Row="1" Grid.Column="1" TextColor="#004FEF" FontAttributes="Bold" />
                            <Label Grid.Row="2" Text="物料属性" TextColor="#4B6688" /><Label x:Name="PropertyLabel" Grid.Row="2" Grid.Column="1" TextColor="#001431" FontAttributes="Bold" />
                            <Label Grid.Row="2" Grid.Column="2" Text="包装方式" TextColor="#4B6688" /><Label x:Name="MethodLabel" Grid.Row="2" Grid.Column="3" TextColor="#001431" FontAttributes="Bold" />
                            <Label Grid.Row="3" Text="包装称重" TextColor="#4B6688" /><Label x:Name="WeightLabel" Grid.Row="3" Grid.Column="1" TextColor="#001431" FontAttributes="Bold" />
                            <Label Grid.Row="3" Grid.Column="2" Text="需包装布" TextColor="#4B6688" /><Label x:Name="ClothLabel" Grid.Row="3" Grid.Column="3" TextColor="#001431" FontAttributes="Bold" />
                            <Label Grid.Row="4" Text="包装布颜色" TextColor="#4B6688" /><Label x:Name="ColorLabel" Grid.Row="4" Grid.Column="1" TextColor="#001431" FontAttributes="Bold" />
                            <Label Grid.Row="4" Grid.Column="2" Text="是否打托" TextColor="#4B6688" /><Label x:Name="PalletLabel" Grid.Row="4" Grid.Column="3" TextColor="#001431" FontAttributes="Bold" />
                        </Grid>
                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*" RowSpacing="16" ColumnSpacing="12">
                            <Label Text="其他要求" TextColor="#4B6688" /><Label x:Name="RequirementLabel" Grid.Column="1" TextColor="#001431" FontAttributes="Bold" HorizontalTextAlignment="End" />
                            <Label Grid.Row="1" Text="生产备注" TextColor="#4B6688" /><Label x:Name="MemoLabel" Grid.Row="1" Grid.Column="1" TextColor="#001431" FontAttributes="Bold" HorizontalTextAlignment="End" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White" StrokeThickness="0" Padding="20,18">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="实际重量 (KG) *" TextColor="#0A2E69" FontAttributes="Bold" />
                        <Entry x:Name="ActualWeightEntry" Placeholder="请输入称重重量" Keyboard="Numeric" BackgroundColor="#F8FAFD" HeightRequest="48" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="2" BackgroundColor="White" StrokeThickness="0" Padding="22,16">
            <Button Text="🖨️  打印并保存" BackgroundColor="#1F447E" TextColor="White" FontSize="17" FontAttributes="Bold" CornerRadius="10" HeightRequest="50" />
        </Border>
    </Grid>
</ContentPage>
