<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JXHLJSApp.Pages.Warehouse.PackagingSubTaskListPage"
             Title="包装作业任务"
             BackgroundColor="#F4F6F9"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*">
        <Border BackgroundColor="#244B88" StrokeThickness="0" Padding="16,22,16,14" HeightRequest="66">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,16,16" /></Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*">
                <Label Text="‹ 返回" TextColor="White" FontSize="15" VerticalOptions="Center">
                    <Label.GestureRecognizers><TapGestureRecognizer Tapped="OnBackTapped" /></Label.GestureRecognizers>
                </Label>
                <Label Grid.Column="1" Text="包装作业任务" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalOptions="Center" Margin="0,0,48,0" />
            </Grid>
        </Border>

        <RefreshView Grid.Row="1" x:Name="RefreshContainer" Refreshing="OnRefreshing">
            <CollectionView x:Name="TaskList" EmptyView="当前没有包装作业任务" Margin="17,16,17,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="White" StrokeThickness="0" Padding="20,18" Margin="0,0,0,14">
                            <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnTaskTapped" /></Border.GestureRecognizers>
                            <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="14" ColumnSpacing="12">
                                <Label Text="{Binding taskNoDisplay}" TextColor="#051B3D" FontSize="18" FontAttributes="Bold" />
                                <Border Grid.Column="1" BackgroundColor="#FFF0DF" StrokeThickness="0" Padding="9,4" VerticalOptions="Start">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                                    <Label Text="{Binding statusDisplay}" TextColor="#F06423" FontSize="13" FontAttributes="Bold" />
                                </Border>
                                <Label Grid.Row="1" TextColor="#38557C" FontSize="14">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="生产工单: " />
                                            <Span Text="{Binding workOrderNoDisplay}" />
                                            <Span Text=" | 钢号: " />
                                            <Span Text="{Binding materialDisplay}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
