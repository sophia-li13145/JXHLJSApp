<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JXHLJSApp.Pages.Warehouse.RawMaterialReceivingSuccessPage"
             Title="操作提示"
             BackgroundColor="#F4F6F9"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*">
        <Border BackgroundColor="#244B88"
                StrokeThickness="0"
                Padding="16,22,16,14"
                HeightRequest="66">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,16,16" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*">
                <Label Text="‹ 返回"
                       TextColor="White"
                       FontSize="15"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnReturnTapped" />
                    </Label.GestureRecognizers>
                </Label>
                <Label Grid.Column="1"
                       Text="操作提示"
                       TextColor="White"
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       VerticalOptions="Center"
                       Margin="0,0,48,0" />
            </Grid>
        </Border>

        <VerticalStackLayout Grid.Row="1"
                             Padding="24,112,24,0"
                             Spacing="22"
                             HorizontalOptions="Center">
            <Border WidthRequest="70"
                    HeightRequest="70"
                    BackgroundColor="#4FD18B"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Label Text="✓"
                       TextColor="White"
                       FontSize="54"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Border>
            <Label Text="采购入库提交成功"
                   TextColor="#001431"
                   FontSize="25"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />
            <Label x:Name="SuccessMessageLabel"
                   Text="数据已录入至 -- - --，当前状态：待质检"
                   TextColor="#4B6688"
                   FontSize="15"
                   HorizontalTextAlignment="Center" />
            <Button Text="完 成 返 回"
                    BackgroundColor="#1F447E"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    WidthRequest="240"
                    HeightRequest="50"
                    Margin="0,28,0,0"
                    Clicked="OnReturnClicked" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
