<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JXHLJSApp.Pages.Transport.OutstockTransportOrderDetailPage"
             Title="出库运输记录"
             BackgroundColor="#F4F6F9"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*,Auto">
        <Border BackgroundColor="#244B88" StrokeThickness="0" Padding="16,22,16,14" HeightRequest="66">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,16,16" /></Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*">
                <Label Text="‹ 返回" TextColor="White" FontSize="15" VerticalOptions="Center">
                    <Label.GestureRecognizers><TapGestureRecognizer Tapped="OnBackTapped" /></Label.GestureRecognizers>
                </Label>
                <Label Grid.Column="1" Text="出库运输记录" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalOptions="Center" Margin="0,0,48,0" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,14,18,24" Spacing="14">
                <Border BackgroundColor="#EAF4FF" Stroke="#A8CCFF" StrokeThickness="1" Padding="18,14">
                    <Border.StrokeShape><RoundRectangle CornerRadius="9" /></Border.StrokeShape>
                    <Label Text="📋 来源于领料单。该页面仅展示单据与明细信息，供查询核对。" TextColor="#0B5CFF" FontSize="14" LineBreakMode="WordWrap" />
                </Border>

                <Border BackgroundColor="White" StrokeThickness="0" Padding="18,18">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*" RowSpacing="18" ColumnSpacing="18">
                        <Label Text="{Binding orderNoDisplay}" TextColor="#001431" FontSize="16" FontAttributes="Bold" />
                        <Label Grid.Row="1" Text="路线" TextColor="#38557C" FontSize="14" />
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding routeDisplay}" TextColor="#001431" FontSize="14" FontAttributes="Bold" HorizontalTextAlignment="End" />
                    </Grid>
                </Border>

                <Border BackgroundColor="White" StrokeThickness="0" Padding="0" Margin="0,0,0,10">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout Padding="0" Spacing="0">
                        <Label Text="出库物料明细" TextColor="#001431" FontSize="16" FontAttributes="Bold" Margin="14,16,14,12" />
                        <Border Stroke="#D9E0EA" StrokeThickness="1" BackgroundColor="White" Margin="0,0,0,16">
                            <Border.StrokeShape><RoundRectangle CornerRadius="9" /></Border.StrokeShape>
                            <VerticalStackLayout Spacing="0">
                                <Grid ColumnDefinitions="*,*,Auto" Padding="14,10" BackgroundColor="#F8FAFD">
                                    <Label Text="物料" TextColor="#001431" FontSize="13" FontAttributes="Bold" />
                                    <Label Grid.Column="1" Text="规格" TextColor="#001431" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="2" Text="数量" TextColor="#001431" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="End" />
                                </Grid>
                                <BoxView HeightRequest="1" Color="#D9E0EA" />
                                <CollectionView x:Name="DetailList" EmptyView="暂无物料明细">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>
                                            <VerticalStackLayout Spacing="0">
                                                <Grid ColumnDefinitions="*,*,Auto" Padding="14,11">
                                                    <Label Text="{Binding materialNameDisplay}" TextColor="#001431" FontSize="13" LineBreakMode="TailTruncation" />
                                                    <Label Grid.Column="1" Text="{Binding specDisplay}" TextColor="#001431" FontSize="13" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="2" Text="{Binding quantityDisplay, StringFormat='{0}件'}" TextColor="#001431" FontSize="13" HorizontalTextAlignment="End" />
                                                </Grid>
                                                <BoxView HeightRequest="1" Color="#D9E0EA" />
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="2" BackgroundColor="White" Stroke="#E1E7F0" StrokeThickness="1" Padding="18,14,18,22">
            <Button Text="返回列表" BackgroundColor="White" TextColor="#001431" BorderColor="#D0D7E2" BorderWidth="1" CornerRadius="8" HeightRequest="50" FontAttributes="Bold" Clicked="OnBackButtonClicked" />
        </Border>
    </Grid>
</ContentPage>
