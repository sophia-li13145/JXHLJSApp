<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" x:Class="JXHLJSApp.Pages.Transport.ProcessTransferConfirmPage" Title="转运任务信息" BackgroundColor="#F4F6F9" Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*">
        <Border BackgroundColor="#244B88" StrokeThickness="0" Padding="16,22,16,14" HeightRequest="66">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,16,16" /></Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*">
                <Label Text="‹ 返回" TextColor="White" FontSize="15" VerticalOptions="Center">
                    <Label.GestureRecognizers><TapGestureRecognizer Tapped="OnCancelTapped" /></Label.GestureRecognizers>
                </Label>
                <Label Grid.Column="1" Text="转运任务信息" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalOptions="Center" Margin="0,0,48,0" />
            </Grid>
        </Border>
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="22,16,22,24" Spacing="14">
                <Border Stroke="#00BD74" StrokeThickness="1.5" BackgroundColor="White" Padding="14,12">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="MaterialNameLabel" TextColor="#001A43" FontSize="14" FontAttributes="Bold" />
                        <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="12">
                            <Label x:Name="SpecLabel" TextColor="#536984" FontSize="11" />
                            <Label x:Name="ProductionAddressLabel" Grid.Column="1" TextColor="#536984" FontSize="11" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="18">
                            <Label x:Name="QuantityLabel" TextColor="#001A43" FontSize="11" FontAttributes="Bold" />
                            <Label x:Name="WeightLabel" Grid.Column="1" TextColor="#001A43" FontSize="11" FontAttributes="Bold" />
                            <Label x:Name="WorkOrderNoLabel" Grid.Column="2" TextColor="#001A43" FontSize="11" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#EEF2F7" />
                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" RowSpacing="12">
                            <Label Text="当前工序" TextColor="#667A96" FontSize="12" />
                            <Label Text="下一道工序" Grid.Row="1" TextColor="#C85B00" FontSize="13" FontAttributes="Bold" />
                            <Label x:Name="CurrentProcessLabel" Grid.Column="1" TextColor="#001431" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="End" />
                            <Label x:Name="NextProcessLabel" Grid.Row="1" Grid.Column="1" TextColor="#C85B00" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="End" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
                <Border BackgroundColor="White" StrokeThickness="0" Padding="16,16">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="执行追踪记录" TextColor="#001A43" FontSize="16" FontAttributes="Bold" />
                        <BoxView HeightRequest="1" Color="#EEF2F7" />
                        <VerticalStackLayout x:Name="TraceListLayout" Spacing="0" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
