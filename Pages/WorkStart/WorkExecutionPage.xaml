<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JXHLJSApp.Pages.WorkStart.WorkExecutionPage"
             BackgroundColor="#F4F6FA"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*">
        <Border BackgroundColor="#244B88" StrokeThickness="0" Padding="18,18,18,14" HeightRequest="66">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,18,18" /></Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Label Text="‹ 返回工单" TextColor="White" FontSize="15" VerticalOptions="Center">
                    <Label.GestureRecognizers><TapGestureRecognizer Tapped="OnBackHomeTapped" /></Label.GestureRecognizers>
                </Label>
                <Label Grid.Column="1" Text="生产执行中" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                <BoxView Grid.Column="2" WidthRequest="64" Opacity="0" />
            </Grid>
        </Border>

        <RefreshView Grid.Row="1" x:Name="RefreshContainer" Refreshing="OnRefreshing">
            <ScrollView>
                <VerticalStackLayout Padding="17,14,17,24" Spacing="16">
                    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                        <Border BackgroundColor="White" StrokeThickness="0" Padding="12" HeightRequest="103">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnInstructionTapped" />
                            </Border.GestureRecognizers>
                            <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                                <Border BackgroundColor="#58AFC3" WidthRequest="44" HeightRequest="44"><Border.StrokeShape><RoundRectangle CornerRadius="22" /></Border.StrokeShape><Label Text="📋" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="20" /></Border>
                                <Label Text="查看指令卡" TextColor="#001431" FontAttributes="Bold" FontSize="14" WidthRequest="82" HorizontalTextAlignment="Center" LineBreakMode="NoWrap" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="White" StrokeThickness="0" Padding="12" HeightRequest="103">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMaterialLoadingTapped" />
                            </Border.GestureRecognizers>
                            <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                            <VerticalStackLayout Spacing="10" HorizontalOptions="Center"><Border BackgroundColor="#62B884" WidthRequest="44" HeightRequest="44"><Border.StrokeShape><RoundRectangle CornerRadius="22" /></Border.StrokeShape><Label Text="📥" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="20" /></Border><Label Text="上料" TextColor="#001431" FontAttributes="Bold" FontSize="14" WidthRequest="82" HorizontalTextAlignment="Center" LineBreakMode="NoWrap" /></VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="2" BackgroundColor="White" StrokeThickness="0" Padding="12" HeightRequest="103"><Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape><VerticalStackLayout Spacing="10" HorizontalOptions="Center"><Border BackgroundColor="#54B4E4" WidthRequest="44" HeightRequest="44"><Border.StrokeShape><RoundRectangle CornerRadius="22" /></Border.StrokeShape><Label Text="📤" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="20" /></Border><Label Text="下料" TextColor="#001431" FontAttributes="Bold" FontSize="14" WidthRequest="82" HorizontalTextAlignment="Center" LineBreakMode="NoWrap" /></VerticalStackLayout></Border>
                        <Border Grid.Row="1" BackgroundColor="White" StrokeThickness="0" Padding="12" HeightRequest="103"><Border.GestureRecognizers><TapGestureRecognizer Tapped="OnAbnormalReportTapped" /></Border.GestureRecognizers><Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape><VerticalStackLayout Spacing="10" HorizontalOptions="Center"><Border BackgroundColor="#F27655" WidthRequest="44" HeightRequest="44"><Border.StrokeShape><RoundRectangle CornerRadius="22" /></Border.StrokeShape><Label Text="⚠️" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="20" /></Border><Label Text="异常上报" TextColor="#001431" FontAttributes="Bold" FontSize="14" WidthRequest="82" HorizontalTextAlignment="Center" LineBreakMode="NoWrap" /></VerticalStackLayout></Border>
                        <Border Grid.Row="1" Grid.Column="1" BackgroundColor="White" StrokeThickness="0" Padding="12" HeightRequest="103"><Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape><VerticalStackLayout Spacing="10" HorizontalOptions="Center"><Border BackgroundColor="#DEBC79" WidthRequest="44" HeightRequest="44"><Border.StrokeShape><RoundRectangle CornerRadius="22" /></Border.StrokeShape><Label Text="↩️" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="20" /></Border><Label Text="返工上报" TextColor="#001431" FontAttributes="Bold" FontSize="14" WidthRequest="82" HorizontalTextAlignment="Center" LineBreakMode="NoWrap" /></VerticalStackLayout></Border>
                        <Border Grid.Row="1" Grid.Column="2" BackgroundColor="White" StrokeThickness="0" Padding="12" HeightRequest="103"><Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape><VerticalStackLayout Spacing="10" HorizontalOptions="Center"><Border BackgroundColor="#8CC665" WidthRequest="44" HeightRequest="44"><Border.StrokeShape><RoundRectangle CornerRadius="22" /></Border.StrokeShape><Label Text="✅" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="20" /></Border><Label Text="完工" TextColor="#001431" FontAttributes="Bold" FontSize="14" WidthRequest="82" HorizontalTextAlignment="Center" LineBreakMode="NoWrap" /></VerticalStackLayout></Border>
                        <Border Grid.Row="2" BackgroundColor="White" StrokeThickness="0" Padding="12" HeightRequest="103"><Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape><VerticalStackLayout Spacing="10" HorizontalOptions="Center"><Border BackgroundColor="#F2C04B" WidthRequest="44" HeightRequest="44"><Border.StrokeShape><RoundRectangle CornerRadius="22" /></Border.StrokeShape><Label Text="⏸️" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="20" /></Border><Label Text="暂停" TextColor="#001431" FontAttributes="Bold" FontSize="14" WidthRequest="82" HorizontalTextAlignment="Center" LineBreakMode="NoWrap" /></VerticalStackLayout></Border>
                        <Border Grid.Row="2" Grid.Column="1" BackgroundColor="White" StrokeThickness="0" Padding="12" HeightRequest="103"><Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape><VerticalStackLayout Spacing="10" HorizontalOptions="Center"><Border BackgroundColor="#A58BE0" WidthRequest="44" HeightRequest="44"><Border.StrokeShape><RoundRectangle CornerRadius="22" /></Border.StrokeShape><Label Text="🔀" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="20" /></Border><Label Text="切换机台" TextColor="#001431" FontAttributes="Bold" FontSize="14" WidthRequest="82" HorizontalTextAlignment="Center" LineBreakMode="NoWrap" /></VerticalStackLayout></Border>
                    </Grid>

                    <Border BackgroundColor="White" Stroke="#244B88" StrokeThickness="2" Padding="20,18">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="当前关联任务池" TextColor="#0A2E69" FontSize="18" FontAttributes="Bold" />
                            <BoxView HeightRequest="1" Color="#DDE6F1" />
                            <CollectionView x:Name="TaskPoolList" EmptyView="暂无当前关联任务">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border BackgroundColor="#F2FFF8" Stroke="#18C77A" StrokeThickness="1" Padding="14" Margin="0,0,0,10">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                                            <VerticalStackLayout Spacing="10">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <Label Text="{Binding workOrderNo}" TextColor="#001431" FontSize="18" FontAttributes="Bold" />
                                                    <Label Grid.Column="1" Text="{Binding workOrderStatus}" TextColor="#00A651" FontAttributes="Bold" />
                                                </Grid>
                                                <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="8">
                                                    <Label Text="所属机台" TextColor="#5C6F8F" />
                                                    <Label Grid.Column="1" Text="{Binding machineDisplay}" TextColor="#001431" FontAttributes="Bold" />
                                                    <Label Grid.Column="2" Text="钢号/规格" TextColor="#5C6F8F" />
                                                    <Label Grid.Column="3" Text="{Binding steelGradeSpecificationDisplay}" TextColor="#001431" FontAttributes="Bold" />
                                                </Grid>
                                                <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="8">
                                                    <Label Text="生产重量" TextColor="#5C6F8F" />
                                                    <Label Grid.Column="1" Text="{Binding completedWeightDisplay}" TextColor="#00A651" FontAttributes="Bold" />
                                                    <Label Grid.Column="2" Text="件数" TextColor="#5C6F8F" />
                                                    <Label Grid.Column="3" Text="{Binding completedQuantityDisplay}" TextColor="#001431" FontAttributes="Bold" />
                                                </Grid>
                                                <BoxView HeightRequest="1" Color="#CDEEDC" />
                                                <Label Text="模序" TextColor="#5C6F8F" />
                                                <Border BackgroundColor="#EEF4FF" StrokeThickness="0" Padding="10">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                                                    <Label Text="{Binding moldSequenceDisplay}" TextColor="#0A2E69" FontAttributes="Bold" LineBreakMode="WordWrap" />
                                                </Border>
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>
    </Grid>
</ContentPage>
