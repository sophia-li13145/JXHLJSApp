<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JXHLJSApp.Pages.WorkStart.AbnormalReportPage"
             BackgroundColor="#F4F6FA" Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*,Auto">
        <Border BackgroundColor="#244B88" StrokeThickness="0" Padding="18,18,18,14" HeightRequest="66">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,18,18" /></Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*,Auto"><Label Text="‹ 取消" TextColor="White" VerticalOptions="Center"><Label.GestureRecognizers><TapGestureRecognizer Tapped="OnBackTapped" /></Label.GestureRecognizers></Label><Label Grid.Column="1" Text="新增异常上报" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center"/><BoxView Grid.Column="2" WidthRequest="48" Opacity="0" /></Grid>
        </Border>
        <ScrollView Grid.Row="1"><VerticalStackLayout Padding="20,16" Spacing="16">
            <Border x:Name="ScanPanel" BackgroundColor="White" Stroke="#244B88" StrokeThickness="1" StrokeDashArray="3,3" Padding="24" HeightRequest="114"><Border.GestureRecognizers><TapGestureRecognizer Tapped="OnScanTapped" /></Border.GestureRecognizers><Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape><VerticalStackLayout Spacing="10" HorizontalOptions="Center" VerticalOptions="Center"><Label Text="📷" FontSize="26" HorizontalTextAlignment="Center"/><Label Text="点击扫码自动识别异常对象" TextColor="#0A2E69" FontSize="15" /></VerticalStackLayout></Border>
            <Border x:Name="MaterialCard" IsVisible="False" BackgroundColor="#F8FBFF" Stroke="#D8E3F3" Padding="16"><Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape><VerticalStackLayout Spacing="14"><Label x:Name="ScannedCodeLabel" Text="--" TextColor="#001431" FontSize="15" FontAttributes="Bold"/><Label x:Name="MaterialTypeLabel" Text="✅ 识别成功" TextColor="#0A2E69" FontSize="16" FontAttributes="Bold"/><Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="14" ColumnSpacing="12"><Label Text="物料编号" TextColor="#5C6F8F"/><Label x:Name="MaterialCodeLabel" Grid.Column="1" TextColor="#001431" FontAttributes="Bold"/><Label Grid.Column="2" Text="钢号" TextColor="#5C6F8F"/><Label x:Name="SteelLabel" Grid.Column="3" TextColor="#001431" FontAttributes="Bold" HorizontalTextAlignment="End"/><Label Grid.Row="1" Text="产地" TextColor="#5C6F8F"/><Label x:Name="OriginLabel" Grid.Row="1" Grid.Column="1" Text="本厂" TextColor="#001431" FontAttributes="Bold"/><Label Grid.Row="1" Grid.Column="2" Text="规格" TextColor="#5C6F8F"/><Label x:Name="SpecLabel" Grid.Row="1" Grid.Column="3" TextColor="#001431" FontAttributes="Bold" HorizontalTextAlignment="End"/><Label Grid.Row="2" Text="重量" TextColor="#5C6F8F"/><Label x:Name="WeightLabel" Grid.Row="2" Grid.Column="1" TextColor="#001431" FontAttributes="Bold"/><Label Grid.Row="3" Text="关联工单" TextColor="#5C6F8F"/><Label x:Name="WorkOrderLabel" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" TextColor="#001431" FontAttributes="Bold" HorizontalTextAlignment="End"/></Grid></VerticalStackLayout></Border>
            <Border BackgroundColor="White" StrokeThickness="0" Padding="18"><Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape><VerticalStackLayout Spacing="14"><Label Text="异常类型 *" TextColor="#001431" FontAttributes="Bold"/><Grid x:Name="AbnormalTypeContainer" ColumnDefinitions="*,*" ColumnSpacing="12" RowSpacing="10"/>
            <Label Text="现场拍照 *" TextColor="#001431" FontAttributes="Bold"/><Border x:Name="PhotoPanel" BackgroundColor="#F8FBFF" Stroke="#BFD0E8" StrokeThickness="2" StrokeDashArray="7,4" Padding="18" HeightRequest="140"><Border.GestureRecognizers><TapGestureRecognizer Tapped="OnPhotoTapped" /></Border.GestureRecognizers><Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape><Grid><VerticalStackLayout x:Name="PhotoPlaceholder" HorizontalOptions="Center" VerticalOptions="Center" Spacing="10"><Label Text="📷" FontSize="30" HorizontalTextAlignment="Center"/><Label x:Name="PhotoHintLabel" Text="点击调用相机拍照" TextColor="#5C6F8F"/></VerticalStackLayout><Image x:Name="PhotoPreviewImage" IsVisible="False" Aspect="AspectFit" HorizontalOptions="Fill" VerticalOptions="Fill"/><Button x:Name="RetakePhotoButton" Text="重拍" IsVisible="False" BackgroundColor="#244B88" TextColor="White" FontAttributes="Bold" CornerRadius="16" Padding="14,6" HorizontalOptions="End" VerticalOptions="End" Clicked="OnRetakePhotoClicked"/><Border x:Name="PhotoLoadingOverlay" IsVisible="False" BackgroundColor="#DFFFFFFF" StrokeThickness="0" InputTransparent="False"><Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape><VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8"><ActivityIndicator x:Name="PhotoLoadingIndicator" IsRunning="False" Color="#244B88" WidthRequest="34" HeightRequest="34"/><Label Text="照片处理中，请稍候..." TextColor="#244B88" FontAttributes="Bold"/></VerticalStackLayout></Border></Grid></Border>
            <Label Text="补充说明" TextColor="#001431" FontAttributes="Bold"/><Editor x:Name="DescriptionEditor" Placeholder="请详细描述异常情况..." AutoSize="TextChanges" HeightRequest="88" BackgroundColor="#F8FBFF" TextColor="#001431"/></VerticalStackLayout></Border>
        </VerticalStackLayout></ScrollView>
        <Border Grid.Row="2" BackgroundColor="White" Padding="20,16"><Button Text="确认上报异常" BackgroundColor="#F53D45" TextColor="White" FontSize="17" FontAttributes="Bold" CornerRadius="10" HeightRequest="56" Clicked="OnSubmitClicked"/></Border>
    </Grid>
</ContentPage>
