<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JXHLJSApp.Pages.WorkStart.MaterialUnloadingPage"
             BackgroundColor="#F4F6FA"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*">
        <Border BackgroundColor="#244B88" StrokeThickness="0" Padding="20,18,20,14" HeightRequest="66">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,18,18" /></Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Label Text="‹ 返回" TextColor="White" FontSize="15" VerticalOptions="Center">
                    <Label.GestureRecognizers><TapGestureRecognizer Tapped="OnBackTapped" /></Label.GestureRecognizers>
                </Label>
                <Label Grid.Column="1" Text="下料作业" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                <BoxView Grid.Column="2" WidthRequest="48" Opacity="0" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="22,18,22,28" Spacing="14">
                <Border x:Name="ScanPanel" BackgroundColor="#EEF6FF" Stroke="#244B88" StrokeThickness="2" StrokeDashArray="6,4" Padding="24" HeightRequest="228">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnScanPanelTapped" /></Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="18" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label x:Name="ScanIconLabel" Text="▣" TextColor="#5A4773" FontSize="48" HorizontalTextAlignment="Center" />
                        <Label x:Name="ScanTitleLabel" Text="1. 扫描机台二维码" TextColor="#001431" FontSize="16" HorizontalTextAlignment="Center" />
                        <Label x:Name="ScanHintLabel" Text="" TextColor="#0057FF" FontSize="16" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <Border x:Name="ManualMachinePanel" BackgroundColor="White" Stroke="#DDE6F1" StrokeThickness="1" Padding="12">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="测试用：手动输入机台码" TextColor="#0B3D8B" FontSize="15" FontAttributes="Bold" />
                        <Grid ColumnDefinitions="*,72" ColumnSpacing="10" VerticalOptions="Center">
                            <Entry x:Name="MachineCodeEntry" Placeholder="输入机台码后确认" PlaceholderColor="#7A8797" FontSize="15" BackgroundColor="#F8FAFD" Completed="OnManualMachineCompleted" />
                            <Button Grid.Column="1" Text="确认" FontSize="16" FontAttributes="Bold" BackgroundColor="#244B88" TextColor="White" CornerRadius="10" Padding="0" Clicked="OnManualMachineConfirmClicked" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border x:Name="SuccessBanner" IsVisible="False" BackgroundColor="#F0FFF7" Stroke="#9BE7B4" StrokeThickness="1" Padding="18,14">
                    <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                    <Label Text="✅ 扫码成功，已记录下料信息！" TextColor="#168A3A" FontSize="15" />
                </Border>

                <Border x:Name="ResultCard" IsVisible="False" BackgroundColor="White" StrokeThickness="0" Padding="20,18">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button Text="返工上报" BackgroundColor="#FF9800" TextColor="White" FontAttributes="Bold" CornerRadius="10" HeightRequest="46" Clicked="OnReworkReportClicked" />
                            <Button Grid.Column="1" Text="异常上报" BackgroundColor="#F43F4B" TextColor="White" FontAttributes="Bold" CornerRadius="10" HeightRequest="46" Clicked="OnAbnormalReportClicked" />
                        </Grid>
                        <Label x:Name="InspectStatusLabel" Text="产品检验状态（系统智能判定）*" TextColor="#001431" FontSize="14" FontAttributes="Bold" />
                        <Entry x:Name="InspectStatusEntry" Text="合格品" TextColor="#00A86B" FontAttributes="Bold" BackgroundColor="#F4F7FB" IsReadOnly="True" />
                        <Picker x:Name="InspectStatusPicker" Title="产品检验状态" TextColor="#00A86B" FontAttributes="Bold" BackgroundColor="#F4F7FB" IsVisible="False" SelectedIndexChanged="OnInspectStatusPickerChanged">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>合格品</x:String>
                                    <x:String>小件</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                        </Picker>
                        <Label x:Name="OutputLengthLabel" Text="产出长度（m）*" TextColor="#001431" FontSize="14" FontAttributes="Bold" />
                        <Entry x:Name="OutputLengthEntry" Keyboard="Numeric" TextColor="#001431" FontAttributes="Bold" BackgroundColor="#F4F7FB" TextChanged="OnManualOutputTextChanged" Completed="OnManualOutputCompleted" />
                        <Label x:Name="PieceWeightLabel" Text="件重（KG）（长度×0.00617×规格²）*" TextColor="#001431" FontSize="14" FontAttributes="Bold" />
                        <Entry x:Name="PieceWeightEntry" Keyboard="Numeric" TextColor="#001431" FontAttributes="Bold" BackgroundColor="#F4F7FB" IsReadOnly="True" />
                        <Grid ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                            <Label Text="上下料对照" TextColor="#001431" FontSize="17" FontAttributes="Bold" />
                            <Border x:Name="MatchBadge" Grid.Column="1" BackgroundColor="#E9FFF2" StrokeThickness="0" Padding="8,3">
                                <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                                <Label x:Name="MatchBadgeLabel" Text="映射匹配" TextColor="#00A86B" FontSize="12" FontAttributes="Bold" />
                            </Border>
                        </Grid>
                        <VerticalStackLayout Spacing="10">
                            <Border BackgroundColor="#F4F7FB" Stroke="#E3EBF6" Padding="14,12">
                                <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="📥 上料信息" TextColor="#5B7DB2" FontSize="12" FontAttributes="Bold" />
                                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" RowSpacing="6" ColumnSpacing="10">
                                        <Label x:Name="InputMaterialCodeLabel" TextColor="#001431" FontAttributes="Bold" />
                                        <Label x:Name="InputSteelGradeLabel" Grid.Column="1" TextColor="#001431" FontAttributes="Bold" />
                                        <Label x:Name="InputOriginPlaceLabel" Grid.Row="1" TextColor="#001431" />
                                        <Label x:Name="InputSpecLabel" Grid.Row="1" Grid.Column="1" TextColor="#001431" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                            <Border BackgroundColor="#EEF6FF" Stroke="#80B8FF" Padding="14,12">
                                <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="📤 下料信息及工单属性" TextColor="#0057FF" FontSize="12" FontAttributes="Bold" />
                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,*" RowSpacing="6" ColumnSpacing="10">
                                        <Label x:Name="MaterialCodeLabel" TextColor="#001431" FontAttributes="Bold" />
                                        <Label x:Name="SteelGradeLabel" Grid.Column="1" TextColor="#001431" FontAttributes="Bold" />
                                        <Label x:Name="OriginPlaceLabel" Grid.Row="1" TextColor="#001431" />
                                        <Label x:Name="SpecLabel" Grid.Row="1" Grid.Column="1" TextColor="#001431" />
                                        <Label x:Name="LengthLabel" Grid.Row="2" TextColor="#4B6688" />
                                        <Label x:Name="WeightLabel" Grid.Row="2" Grid.Column="1" TextColor="#4B6688" />
                                        <Grid Grid.Row="3" Grid.ColumnSpan="2" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8" Margin="0,8,0,0">
                                            <Label Text="生产指令单" TextColor="#4B6688" FontSize="12" VerticalOptions="Center" />
                                            <Label x:Name="OutputWorkOrderNoLabel" Grid.Column="1" TextColor="#0057FF" FontSize="12" FontAttributes="Bold" LineBreakMode="WordWrap" />
                                            <Label Text="机台" Grid.Column="2" TextColor="#4B6688" FontSize="12" VerticalOptions="Center" HorizontalTextAlignment="End" />
                                            <Label x:Name="OutputMachineLabel" Grid.Column="3" TextColor="#001431" FontSize="12" FontAttributes="Bold" VerticalOptions="Center" HorizontalTextAlignment="End" />
                                        </Grid>
                                        <Grid Grid.Row="4" Grid.ColumnSpan="2" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                                            <Label Text="客户代码" TextColor="#4B6688" FontSize="12" VerticalOptions="Center" />
                                            <Label x:Name="OutputCustomerCodeLabel" Grid.Column="1" TextColor="#001431" FontSize="12" FontAttributes="Bold" />
                                            <Label Text="当前序号" Grid.Column="2" TextColor="#4B6688" FontSize="12" VerticalOptions="Center" HorizontalTextAlignment="End" />
                                            <Label x:Name="OutputSequenceLabel" Grid.Column="3" TextColor="#001431" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="End" />
                                        </Grid>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                        <Button x:Name="ConfirmButton" Text="确认提交下料" BackgroundColor="#244B88" TextColor="White" FontSize="17" FontAttributes="Bold" CornerRadius="10" HeightRequest="54" Clicked="OnConfirmBackClicked" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
