<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JXHLJSApp.Pages.WorkStart.WorkStartScanPage"
             BackgroundColor="#F4F6FA"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*">
        <Border BackgroundColor="#244B88" StrokeThickness="0" Padding="20,18,20,14" HeightRequest="66">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,18,18" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Label Text="‹ 返回" TextColor="White" FontSize="15" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Label.GestureRecognizers>
                </Label>
                <Label Grid.Column="1" Text="扫码上机" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalOptions="Center" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" RowDefinitions="*,Auto,Auto,3*" Padding="23,40,23,0" RowSpacing="18">
            <Border Grid.Row="0" BackgroundColor="White" Stroke="#244B88" StrokeThickness="2" Padding="22">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12" VerticalOptions="Center" HorizontalOptions="Center">
                    <Border WidthRequest="64" HeightRequest="64" BackgroundColor="#C7B7DD" Stroke="#5A4773" StrokeThickness="5">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="4" />
                        </Border.StrokeShape>
                    </Border>
                    <Label Text="点击直接扫描机台二维码" TextColor="#0B3D8B" FontSize="18" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                    <Label Text="扫码获取该机台关联任务计划" TextColor="#8BA0C0" FontSize="14" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnScanTapped" />
                </Border.GestureRecognizers>
            </Border>

            <Label Grid.Row="1" Text="或" TextColor="#647895" FontSize="14" HorizontalTextAlignment="Center" />

            <Border Grid.Row="2" BackgroundColor="White" Stroke="#DDE6F1" StrokeThickness="1" Padding="12" HeightRequest="68">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,66" ColumnSpacing="10" VerticalOptions="Center">
                    <Entry x:Name="MachineNoEntry" Placeholder="手动输入机台编号" PlaceholderColor="#7A8797" FontSize="15" BackgroundColor="#F8FAFD" />
                    <Button Grid.Column="1" Text="确认" FontSize="16" FontAttributes="Bold" BackgroundColor="#0B3D8B" TextColor="White" CornerRadius="14" Padding="0" Clicked="OnConfirmClicked" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
