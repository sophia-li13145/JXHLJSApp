<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JXHLJSApp.Pages.WorkOrders.WorkOrderTaskListPage"
             BackgroundColor="#F3F6FA"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*">
        <Border BackgroundColor="#244B88" StrokeThickness="0" Padding="18,18,18,14" HeightRequest="66">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,18,18" /></Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Label Text="‹ 返回" TextColor="White" FontSize="15" VerticalOptions="Center">
                    <Label.GestureRecognizers><TapGestureRecognizer Tapped="OnBackTapped" /></Label.GestureRecognizers>
                </Label>
                <Label Grid.Column="1" Text="生产任务列表" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                <BoxView Grid.Column="2" WidthRequest="42" Opacity="0" />
            </Grid>
        </Border>

        <RefreshView Grid.Row="1" x:Name="RefreshContainer" Refreshing="OnRefreshing">
            <Grid RowDefinitions="Auto,*" Padding="20,16,20,24" RowSpacing="16">
                <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout x:Name="MachineButtonLayout" Spacing="12" />
                </ScrollView>

                <CollectionView x:Name="TaskList" Grid.Row="1" EmptyView="暂无任务">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="White" StrokeThickness="0" Padding="20,18" Margin="0,0,0,14">
                                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                                <VerticalStackLayout Spacing="12">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding workOrderNo}" FontSize="18" FontAttributes="Bold" TextColor="#001431" />
                                        <Border Grid.Column="1" BackgroundColor="{Binding statusBackgroundColor}" StrokeThickness="0" Padding="10,5">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="6" /></Border.StrokeShape>
                                            <Label Text="{Binding workOrderStatus}" TextColor="{Binding statusTextColor}" FontSize="13" FontAttributes="Bold" />
                                        </Border>
                                    </Grid>
                                    <Label Text="{Binding machineDisplay, StringFormat='机台: {0}'}" FontSize="13" TextColor="#4B6688" />
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                                        <Label Text="{Binding operationDisplay, StringFormat='工序：{0}'}" FontSize="14" TextColor="#4B6688" />
                                        <Label Grid.Column="1" Text="{Binding productionWeightDisplay, StringFormat='生产重量：{0}'}" FontSize="14" TextColor="#4B6688" />
                                    </Grid>
                                    <Button Text="📋  查看生产指令卡"
                                            BackgroundColor="White"
                                            TextColor="#001431"
                                            BorderColor="#CCD6E2"
                                            BorderWidth="1"
                                            FontAttributes="Bold"
                                            CornerRadius="6"
                                            HeightRequest="40"
                                            Clicked="OnInstructionClicked"
                                            CommandParameter="{Binding id}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </RefreshView>
    </Grid>
</ContentPage>
