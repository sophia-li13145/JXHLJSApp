<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JXHLJSApp.Pages.LoginPage"
             BackgroundColor="#F3F6FA"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                BackgroundColor="#244B88"
                StrokeThickness="0"
                Padding="18,34,18,0"
                HeightRequest="105">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,20,20" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Start">
                <Label Text="华立钢丝 MES"
                       TextColor="White"
                       FontSize="24"
                       FontAttributes="Bold"
                       VerticalOptions="Center" />
                <Border Grid.Column="1"
                        BackgroundColor="#5C7DB8"
                        StrokeThickness="0"
                        Padding="14,7"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <Label Text="V2.7 (Max)"
                           TextColor="White"
                           FontSize="13"
                           FontAttributes="Bold" />
                </Border>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,0,18,28" Spacing="34">
                <Grid HeightRequest="53"
                      Margin="0,0,0,0"
                      ColumnDefinitions="*,*">
                    <Border Grid.ColumnSpan="2"
                            BackgroundColor="#E4EAF2"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="0,0,10,10" />
                        </Border.StrokeShape>
                    </Border>
                    <Label Text="扫码登录"
                           TextColor="#5D718D"
                           FontSize="16"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                    <Border Grid.Column="1"
                            Margin="0,0,0,5"
                            BackgroundColor="White"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="0,0,8,8" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#22000000" Offset="0,2" Radius="4" />
                        </Border.Shadow>
                        <Label Text="账号登录"
                               TextColor="#082D63"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                </Grid>

                <Border BackgroundColor="White"
                        Stroke="#DDE5F0"
                        StrokeThickness="1"
                        Padding="20,20,20,20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="18">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="工号/账号"
                                   TextColor="#0D2D59"
                                   FontSize="16"
                                   FontAttributes="Bold" />
                            <Border BackgroundColor="#F8FAFC"
                                    Stroke="#D8E1ED"
                                    StrokeThickness="1"
                                    HeightRequest="50">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>
                                <Entry x:Name="UsernameEntry"
                                       Placeholder="请输入您的账号"
                                       PlaceholderColor="#8A98AA"
                                       TextColor="#1A2B3C"
                                       BackgroundColor="Transparent"
                                       Margin="12,0"
                                       ClearButtonVisibility="WhileEditing"
                                       ReturnType="Next" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="密码"
                                   TextColor="#0D2D59"
                                   FontSize="13"
                                   FontAttributes="Bold" />
                            <Border BackgroundColor="#F8FAFC"
                                    Stroke="#D8E1ED"
                                    StrokeThickness="1"
                                    HeightRequest="50">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="*,Auto">
                                    <Entry x:Name="PasswordEntry"
                                           Placeholder="请输入密码"
                                           PlaceholderColor="#8A98AA"
                                           TextColor="#1A2B3C"
                                           IsPassword="True"
                                           BackgroundColor="Transparent"
                                           Margin="12,0,4,0"
                                           ReturnType="Done"
                                           Completed="OnPasswordCompleted" />
                                    <Button x:Name="TogglePasswordVisibilityButton"
                                            Grid.Column="1"
                                            Text="显示"
                                            TextColor="#244B88"
                                            FontSize="13"
                                            FontAttributes="Bold"
                                            BackgroundColor="Transparent"
                                            Padding="10,0,12,0"
                                            MinimumWidthRequest="52"
                                            SemanticProperties.Description="显示密码"
                                            Clicked="OnTogglePasswordVisibilityClicked" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*,Auto" Margin="20,-10,20,0">
                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <CheckBox x:Name="RememberCheckBox"
                                  Color="#244B88"
                                  WidthRequest="22"
                                  HeightRequest="22"
                                  CheckedChanged="OnRememberCheckedChanged" />
                        <Label Text="记住密码"
                               TextColor="#334A66"
                               FontSize="15"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <Label Grid.Column="1"
                           Text="忘记密码?"
                           TextColor="#0D3E7D"
                           FontSize="15"
                           FontAttributes="Bold"
                           VerticalOptions="Center" />
                </Grid>

                <Button x:Name="LoginButton"
                        Text="登 录 系 统"
                        BackgroundColor="#214779"
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold"
                        HeightRequest="54"
                        CornerRadius="9"
                        Margin="20,-6,20,0"
                        Clicked="OnLoginClicked">
                    <Button.Shadow>
                        <Shadow Brush="#33000000" Offset="0,6" Radius="10" />
                    </Button.Shadow>
                </Button>

                <Label x:Name="MessageLabel"
                       TextColor="#C0392B"
                       FontSize="14"
                       HorizontalOptions="Center"
                       IsVisible="False" />
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="1"
              Margin="18,0,18,10"
              VerticalOptions="End"
              ColumnDefinitions="Auto,*,Auto">
            <Label Text="日志"
                   TextColor="#5D718D"
                   FontSize="12"
                   TextDecorations="Underline"
                   VerticalOptions="End">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogTapped" />
                </Label.GestureRecognizers>
            </Label>
            <Label Grid.Column="2"
                   Text="管理员界面"
                   TextColor="#5D718D"
                   FontSize="12"
                   TextDecorations="Underline"
                   VerticalOptions="End">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAdminTapped" />
                </Label.GestureRecognizers>
            </Label>
        </Grid>
    </Grid>
</ContentPage>
