<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JXHLJSApp.Pages.Quality.IncomingQualityOrderDetailPage"
             Title="质检任务详情"
             BackgroundColor="#F4F6F9"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*,Auto">
        <Border BackgroundColor="#244B88" StrokeThickness="0" Padding="16,22,16,14" HeightRequest="66">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,16,16" /></Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*">
                <Label Text="‹ 返回列表" TextColor="White" FontSize="15" VerticalOptions="Center">
                    <Label.GestureRecognizers><TapGestureRecognizer Tapped="OnBackTapped" /></Label.GestureRecognizers>
                </Label>
                <Label Grid.Column="1" Text="质检任务详情" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalOptions="Center" Margin="0,0,74,0" />
            </Grid>
        </Border>
        <RefreshView Grid.Row="1" x:Name="RefreshContainer" Refreshing="OnRefreshing">
            <ScrollView>
                <VerticalStackLayout Padding="20,16" Spacing="18">
                    <Border BackgroundColor="White" StrokeThickness="0" Padding="18">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                        <VerticalStackLayout Spacing="14">
                            <Label Text="来料任务信息" TextColor="#00346F" FontSize="16" FontAttributes="Bold" />
                            <BoxView HeightRequest="1" Color="#C8D2DF" />
                            <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="18" ColumnSpacing="10">
                                <Label Text="质检单号" TextColor="#38557C" FontSize="14" />
                                <Label x:Name="QualityNoLabel" Grid.Column="1" TextColor="#051B3D" FontSize="15" FontAttributes="Bold" LineBreakMode="WordWrap" />
                                <Label Grid.Column="2" Text="入库单号" TextColor="#38557C" FontSize="14" />
                                <Label x:Name="InstockNoLabel" Grid.Column="3" TextColor="#051B3D" FontSize="15" FontAttributes="Bold" HorizontalTextAlignment="End" />
                                <Label Grid.Row="1" Text="当前状态" TextColor="#38557C" FontSize="14" VerticalOptions="Center" />
                                <Border x:Name="StatusBadge" Grid.Row="1" Grid.Column="1" BackgroundColor="#F2F4F8" StrokeThickness="0" Padding="10,4" HorizontalOptions="Start">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="7" /></Border.StrokeShape>
                                    <Label x:Name="StatusLabel" TextColor="#051B3D" FontSize="13" FontAttributes="Bold" />
                                </Border>
                                <Label x:Name="MaterialNameTitle" Grid.Row="2" Text="物料名称" TextColor="#38557C" FontSize="14" IsVisible="False" />
                                <Label x:Name="MaterialNameLabel" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" TextColor="#051B3D" FontSize="15" FontAttributes="Bold" HorizontalTextAlignment="End" IsVisible="False" />
                                <Label x:Name="SpecTitle" Grid.Row="3" Text="规格参数" TextColor="#38557C" FontSize="14" IsVisible="False" />
                                <Label x:Name="SpecLabel" Grid.Row="3" Grid.Column="1" TextColor="#0057FF" FontSize="15" FontAttributes="Bold" IsVisible="False" />
                                <Label x:Name="TotalTitle" Grid.Row="3" Grid.Column="2" Text="总数量" TextColor="#38557C" FontSize="14" IsVisible="False" />
                                <Label x:Name="TotalLabel" Grid.Row="3" Grid.Column="3" TextColor="#051B3D" FontSize="15" FontAttributes="Bold" HorizontalTextAlignment="End" IsVisible="False" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                    <Grid x:Name="ScanRecordsHeader" ColumnDefinitions="*,Auto">
                        <Label Text="多次扫码检验记录" TextColor="#00346F" FontSize="16" FontAttributes="Bold" />
                        <Label x:Name="ScanCountLabel" Grid.Column="1" TextColor="#38557C" FontSize="14" />
                    </Grid>
                    <CollectionView x:Name="ScanRecordList" EmptyView="暂无扫码检验记录">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="White" StrokeThickness="0" Padding="0" Margin="0,0,0,12">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                                    <Grid ColumnDefinitions="4,*">
                                        <BoxView Color="#FF4D5E" />
                                        <Grid Grid.Column="1" Padding="14,16" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="8">
                                            <Label Text="{Binding qrCodeDisplay, StringFormat='条码：{0}'}" TextColor="#00346F" FontAttributes="Bold" FontSize="15" />
                                            <Label Grid.Column="1" Text="{Binding inspectResultDisplay}" TextColor="{Binding inspectResultColor}" FontAttributes="Bold" FontSize="14" />
                                            <Label Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding problemPointDisplay, StringFormat='检测结果说明：{0}'}" TextColor="#38557C" FontSize="13" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>
        <Grid x:Name="ActionBar" Grid.Row="2" Padding="20,16" ColumnSpacing="12" BackgroundColor="White" />
    </Grid>
</ContentPage>
