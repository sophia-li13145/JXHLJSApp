<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JXHLJSApp.Pages.Quality.MachineQualityDetailPage"
             BackgroundColor="#F4F6FA"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*,Auto">
        <Border BackgroundColor="#244B88" StrokeThickness="0" Padding="16,22,16,14" HeightRequest="80">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,18,18" /></Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Label Text="‹ 返回" TextColor="White" FontSize="15" VerticalOptions="Center">
                    <Label.GestureRecognizers><TapGestureRecognizer Tapped="OnBackTapped" /></Label.GestureRecognizers>
                </Label>
                <Label x:Name="TitleLabel" Grid.Column="1" Text="执行工序质检" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                <Button x:Name="ScanMaterialButton" Grid.Column="2" Text="▣  扫物料" BackgroundColor="White" TextColor="#0B3D8B" BorderColor="#0B3D8B" BorderWidth="1" CornerRadius="8" HeightRequest="38" Padding="10,0" FontSize="13" FontAttributes="Bold" Clicked="OnScanMaterialClicked" IsVisible="False" />
            </Grid>
        </Border>
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="22,18" Spacing="18">
                <Border BackgroundColor="White" Stroke="#DDE6F1" StrokeThickness="1" Padding="20">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label x:Name="InfoTitleLabel" Text="生产卡片信息" TextColor="#00346F" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" />
                            <Button x:Name="InfoScanMaterialButton" Grid.Column="1" Text="▣  扫描物料" BackgroundColor="White" TextColor="#0B3D8B" BorderColor="#0B3D8B" BorderWidth="1" CornerRadius="6" HeightRequest="34" Padding="10,0" FontSize="13" FontAttributes="Bold" Clicked="OnScanMaterialClicked" IsVisible="False" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="#C8D2DF" />
                        <Grid x:Name="InfoGrid" ColumnDefinitions="*,*" RowSpacing="14" ColumnSpacing="16" />
                    </VerticalStackLayout>
                </Border>

                <Border x:Name="MaterialInfoCard" BackgroundColor="White" Stroke="#DDE6F1" StrokeThickness="1" Padding="20" IsVisible="False">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="物料信息" TextColor="#00346F" FontSize="16" FontAttributes="Bold" />
                        <BoxView HeightRequest="1" Color="#C8D2DF" />
                        <Grid x:Name="MaterialGrid" ColumnDefinitions="*,*" RowSpacing="14" ColumnSpacing="16" />
                    </VerticalStackLayout>
                </Border>
                <Border x:Name="InspectionItemCard" BackgroundColor="White" Stroke="#DDE6F1" StrokeThickness="1" Padding="20" IsVisible="False">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="检验项目标准" TextColor="#00346F" FontSize="16" FontAttributes="Bold" />
                        <BoxView HeightRequest="1" Color="#C8D2DF" />
                        <VerticalStackLayout x:Name="InspectionItemList" Spacing="10" />
                    </VerticalStackLayout>
                </Border>
                <Border BackgroundColor="White" StrokeThickness="0" Padding="20">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="16">
                        <Label x:Name="InputTitleLabel" Text="检验项目录入" TextColor="#051B3D" FontSize="18" FontAttributes="Bold" />
                        <VerticalStackLayout x:Name="AcidInputPanel" Spacing="16" IsVisible="False">
                            <Label Text="检验日期 (年月日) *" TextColor="#051B3D" FontAttributes="Bold" />
                            <DatePicker x:Name="AcidDatePicker" Format="yyyy/MM/dd" BackgroundColor="#F8FAFD" TextColor="#051B3D" />
                            <Label Text="磷化温度" TextColor="#051B3D" FontAttributes="Bold" />
                            <Grid ColumnDefinitions="*,36" ColumnSpacing="0">
                                <Entry x:Name="PhosphatingTemperatureEntry" Placeholder="手动录入" Keyboard="Numeric" BackgroundColor="#F8FAFD" />
                                <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                    <Button Text="▲" HeightRequest="24" Padding="0" FontSize="10" BackgroundColor="#F8FAFD" TextColor="#7A8798" BorderColor="#DDE6F1" BorderWidth="0" CommandParameter="{x:Reference PhosphatingTemperatureEntry}" Clicked="OnIncrementNumericClicked" />
                                    <Button Text="▼" HeightRequest="24" Padding="0" FontSize="10" BackgroundColor="#F8FAFD" TextColor="#7A8798" BorderColor="#DDE6F1" BorderWidth="0" CommandParameter="{x:Reference PhosphatingTemperatureEntry}" Clicked="OnDecrementNumericClicked" />
                                </VerticalStackLayout>
                            </Grid>
                            <Label Text="总酸" TextColor="#051B3D" FontAttributes="Bold" />
                            <Grid ColumnDefinitions="*,36" ColumnSpacing="0">
                                <Entry x:Name="TotalAcidEntry" Placeholder="手动录入" Keyboard="Numeric" BackgroundColor="#F8FAFD" />
                                <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                    <Button Text="▲" HeightRequest="24" Padding="0" FontSize="10" BackgroundColor="#F8FAFD" TextColor="#7A8798" BorderColor="#DDE6F1" BorderWidth="0" CommandParameter="{x:Reference TotalAcidEntry}" Clicked="OnIncrementNumericClicked" />
                                    <Button Text="▼" HeightRequest="24" Padding="0" FontSize="10" BackgroundColor="#F8FAFD" TextColor="#7A8798" BorderColor="#DDE6F1" BorderWidth="0" CommandParameter="{x:Reference TotalAcidEntry}" Clicked="OnDecrementNumericClicked" />
                                </VerticalStackLayout>
                            </Grid>
                            <Label Text="游离酸" TextColor="#051B3D" FontAttributes="Bold" />
                            <Grid ColumnDefinitions="*,36" ColumnSpacing="0">
                                <Entry x:Name="FreeAcidEntry" Placeholder="手动录入" Keyboard="Numeric" BackgroundColor="#F8FAFD" />
                                <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                    <Button Text="▲" HeightRequest="24" Padding="0" FontSize="10" BackgroundColor="#F8FAFD" TextColor="#7A8798" BorderColor="#DDE6F1" BorderWidth="0" CommandParameter="{x:Reference FreeAcidEntry}" Clicked="OnIncrementNumericClicked" />
                                    <Button Text="▼" HeightRequest="24" Padding="0" FontSize="10" BackgroundColor="#F8FAFD" TextColor="#7A8798" BorderColor="#DDE6F1" BorderWidth="0" CommandParameter="{x:Reference FreeAcidEntry}" Clicked="OnDecrementNumericClicked" />
                                </VerticalStackLayout>
                            </Grid>
                            <Label Text="皂化温度" TextColor="#051B3D" FontAttributes="Bold" />
                            <Grid ColumnDefinitions="*,36" ColumnSpacing="0">
                                <Entry x:Name="SaponificationTemperatureEntry" Placeholder="手动录入" Keyboard="Numeric" BackgroundColor="#F8FAFD" />
                                <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                    <Button Text="▲" HeightRequest="24" Padding="0" FontSize="10" BackgroundColor="#F8FAFD" TextColor="#7A8798" BorderColor="#DDE6F1" BorderWidth="0" CommandParameter="{x:Reference SaponificationTemperatureEntry}" Clicked="OnIncrementNumericClicked" />
                                    <Button Text="▼" HeightRequest="24" Padding="0" FontSize="10" BackgroundColor="#F8FAFD" TextColor="#7A8798" BorderColor="#DDE6F1" BorderWidth="0" CommandParameter="{x:Reference SaponificationTemperatureEntry}" Clicked="OnDecrementNumericClicked" />
                                </VerticalStackLayout>
                            </Grid>
                            <Label Text="皂化PH值" TextColor="#051B3D" FontAttributes="Bold" />
                            <Grid ColumnDefinitions="*,36" ColumnSpacing="0">
                                <Entry x:Name="SaponificationPhEntry" Placeholder="手动录入" Keyboard="Numeric" BackgroundColor="#F8FAFD" />
                                <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                    <Button Text="▲" HeightRequest="24" Padding="0" FontSize="10" BackgroundColor="#F8FAFD" TextColor="#7A8798" BorderColor="#DDE6F1" BorderWidth="0" CommandParameter="{x:Reference SaponificationPhEntry}" Clicked="OnIncrementNumericClicked" />
                                    <Button Text="▼" HeightRequest="24" Padding="0" FontSize="10" BackgroundColor="#F8FAFD" TextColor="#7A8798" BorderColor="#DDE6F1" BorderWidth="0" CommandParameter="{x:Reference SaponificationPhEntry}" Clicked="OnDecrementNumericClicked" />
                                </VerticalStackLayout>
                            </Grid>
                            <Label Text="盐酸1浓度" TextColor="#051B3D" FontAttributes="Bold" />
                            <Grid ColumnDefinitions="*,36" ColumnSpacing="0">
                                <Entry x:Name="HydrochloricAcid1Entry" Placeholder="手动录入" Keyboard="Numeric" BackgroundColor="#F8FAFD" />
                                <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                    <Button Text="▲" HeightRequest="24" Padding="0" FontSize="10" BackgroundColor="#F8FAFD" TextColor="#7A8798" BorderColor="#DDE6F1" BorderWidth="0" CommandParameter="{x:Reference HydrochloricAcid1Entry}" Clicked="OnIncrementNumericClicked" />
                                    <Button Text="▼" HeightRequest="24" Padding="0" FontSize="10" BackgroundColor="#F8FAFD" TextColor="#7A8798" BorderColor="#DDE6F1" BorderWidth="0" CommandParameter="{x:Reference HydrochloricAcid1Entry}" Clicked="OnDecrementNumericClicked" />
                                </VerticalStackLayout>
                            </Grid>
                            <Label Text="盐酸2浓度" TextColor="#051B3D" FontAttributes="Bold" />
                            <Grid ColumnDefinitions="*,36" ColumnSpacing="0">
                                <Entry x:Name="HydrochloricAcid2Entry" Placeholder="手动录入" Keyboard="Numeric" BackgroundColor="#F8FAFD" />
                                <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                    <Button Text="▲" HeightRequest="24" Padding="0" FontSize="10" BackgroundColor="#F8FAFD" TextColor="#7A8798" BorderColor="#DDE6F1" BorderWidth="0" CommandParameter="{x:Reference HydrochloricAcid2Entry}" Clicked="OnIncrementNumericClicked" />
                                    <Button Text="▼" HeightRequest="24" Padding="0" FontSize="10" BackgroundColor="#F8FAFD" TextColor="#7A8798" BorderColor="#DDE6F1" BorderWidth="0" CommandParameter="{x:Reference HydrochloricAcid2Entry}" Clicked="OnDecrementNumericClicked" />
                                </VerticalStackLayout>
                            </Grid>
                            <Label Text="总酸取样" TextColor="#051B3D" FontAttributes="Bold" />
                            <Entry x:Name="TotalAcidSamplingEntry" Placeholder="手动录入" BackgroundColor="#F8FAFD" />
                            <Label Text="游离酸取样" TextColor="#051B3D" FontAttributes="Bold" />
                            <Entry x:Name="FreeAcidSamplingEntry" Placeholder="手动录入" BackgroundColor="#F8FAFD" />
                            <Label Text="酸比" TextColor="#051B3D" FontAttributes="Bold" />
                            <Grid ColumnDefinitions="*,36" ColumnSpacing="0">
                                <Entry x:Name="AcidRatioEntry" Placeholder="手动录入" Keyboard="Numeric" BackgroundColor="#F8FAFD" />
                                <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                    <Button Text="▲" HeightRequest="24" Padding="0" FontSize="10" BackgroundColor="#F8FAFD" TextColor="#7A8798" BorderColor="#DDE6F1" BorderWidth="0" CommandParameter="{x:Reference AcidRatioEntry}" Clicked="OnIncrementNumericClicked" />
                                    <Button Text="▼" HeightRequest="24" Padding="0" FontSize="10" BackgroundColor="#F8FAFD" TextColor="#7A8798" BorderColor="#DDE6F1" BorderWidth="0" CommandParameter="{x:Reference AcidRatioEntry}" Clicked="OnDecrementNumericClicked" />
                                </VerticalStackLayout>
                            </Grid>
                            <Label Text="记录人 *" TextColor="#051B3D" FontAttributes="Bold" />
                            <Entry x:Name="RecorderEntry" IsReadOnly="True" BackgroundColor="#EEF3FA" />
                        </VerticalStackLayout>
                        <VerticalStackLayout x:Name="ProcessInputPanel" Spacing="16">
                        <Label Text="圈径控制" TextColor="#051B3D" FontAttributes="Bold" />
                        <Picker x:Name="CoilDiameterPicker" BackgroundColor="#F8FAFD" TextColor="#051B3D" />
                        <Label Text="圈距控制" TextColor="#051B3D" FontAttributes="Bold" />
                        <Picker x:Name="CoilPitchPicker" BackgroundColor="#F8FAFD" TextColor="#051B3D" />
                        <Label Text="实测直径 (mm) *" TextColor="#051B3D" FontAttributes="Bold" />
                        <Entry x:Name="ActualDiameterEntry" Placeholder="输入测量直径" Keyboard="Numeric" BackgroundColor="#F8FAFD" />
                        <Label Text="实测强度 (MPa)" TextColor="#051B3D" FontAttributes="Bold" />
                        <Entry x:Name="StrengthEntry" Placeholder="检测强度值" Keyboard="Numeric" BackgroundColor="#F8FAFD" />
                        <Label Text="延伸率 (%)" TextColor="#051B3D" FontAttributes="Bold" />
                        <Entry x:Name="ElongationEntry" Placeholder="可为空" Keyboard="Numeric" BackgroundColor="#F8FAFD" />
                        <Label Text="表面状态" TextColor="#051B3D" FontAttributes="Bold" />
                        <Entry x:Name="SurfaceEntry" Placeholder="正常" BackgroundColor="#F8FAFD" />
                        </VerticalStackLayout>
                        <VerticalStackLayout x:Name="HeatTreatmentInputPanel" Spacing="16" IsVisible="False">
                            <Label Text="实测直径 (mm) *" TextColor="#051B3D" FontAttributes="Bold" />
                            <Entry x:Name="HeatActualDiameterEntry" Placeholder="输入测量直径" Keyboard="Numeric" TextChanged="OnHeatDiameterTextChanged" BackgroundColor="#F8FAFD" />
                            <Label Text="标准直径 (mm)" TextColor="#051B3D" FontAttributes="Bold" />
                            <Entry x:Name="StandardDiameterEntry" Placeholder="标准直径" Keyboard="Numeric" BackgroundColor="#EEF3FA" IsReadOnly="True" FontAttributes="Bold" />
                            <Label Text="断后直径 (mm) *" TextColor="#051B3D" FontAttributes="Bold" />
                            <Entry x:Name="BrokenDiameterEntry" Placeholder="输入断后直径" Keyboard="Numeric" TextChanged="OnHeatDiameterTextChanged" BackgroundColor="#F8FAFD" />
                            <Border BackgroundColor="#ECFBF1" Stroke="#B9F1CB" StrokeThickness="1" Padding="14">
                                <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="断面收缩率 (%)" TextColor="#009C44" FontAttributes="Bold" />
                                    <Label x:Name="SectionShrinkageLabel" Text="-" TextColor="#009C44" FontSize="20" FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </Border>
                            <Label Text="实测抗拉强度 (MPa) *" TextColor="#051B3D" FontAttributes="Bold" />
                            <Entry x:Name="TensileStrengthEntry" Placeholder="输入抗拉强度" Keyboard="Numeric" BackgroundColor="#F8FAFD" />
                            <Label Text="延伸率 (%)" TextColor="#051B3D" FontAttributes="Bold" />
                            <Entry x:Name="HeatElongationEntry" Placeholder="可为空" Keyboard="Numeric" BackgroundColor="#F8FAFD" />
                            <Label Text="扭转次数" TextColor="#051B3D" FontAttributes="Bold" />
                            <Entry x:Name="TwistCountEntry" Placeholder="输入扭转次数" Keyboard="Numeric" BackgroundColor="#F8FAFD" />
                        </VerticalStackLayout>
                        <Border BackgroundColor="#EAF4FF" Stroke="#BBD8FF" StrokeThickness="1" Padding="16">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="质检结果" TextColor="#0042AD" FontSize="14" FontAttributes="Bold" />
                                <Picker x:Name="InspectResultPicker" BackgroundColor="#F8FAFD" TextColor="#051B3D" />
                            </VerticalStackLayout>
                        </Border>
                        <Label x:Name="MemoLabel" Text="质检备注" TextColor="#051B3D" FontAttributes="Bold" />
                        <Editor x:Name="MemoEditor" Placeholder="填写其他备注信息..." AutoSize="TextChanges" HeightRequest="90" BackgroundColor="#F8FAFD" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
        <Grid x:Name="ActionBar" Grid.Row="2" Margin="6,16" ColumnDefinitions="*,*" ColumnSpacing="12">
            <Button x:Name="SubmitButton" Text="提交质检" TextColor="#0B3D8B" BackgroundColor="White" BorderColor="#0B3D8B" BorderWidth="1" CornerRadius="10" HeightRequest="54" FontAttributes="Bold" Clicked="OnSubmitClicked" />
            <Button x:Name="CompleteButton" Grid.Column="1" IsVisible="False" Text="完 成" TextColor="White" BackgroundColor="#244B88" CornerRadius="10" HeightRequest="54" FontAttributes="Bold" Clicked="OnCompleteClicked" />
        </Grid>
    </Grid>
</ContentPage>
