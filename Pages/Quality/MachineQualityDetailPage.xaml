<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JXHLJSApp.Pages.Quality.MachineQualityDetailPage"
             BackgroundColor="#F4F6FA"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*,Auto">
        <Border BackgroundColor="#244B88" StrokeThickness="0" Padding="16,22,16,14" HeightRequest="80">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,18,18" /></Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*">
                <Label Text="‹ 返回" TextColor="White" FontSize="15" VerticalOptions="Center">
                    <Label.GestureRecognizers><TapGestureRecognizer Tapped="OnBackTapped" /></Label.GestureRecognizers>
                </Label>
                <Label Grid.Column="1" Text="执行工序质检" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalOptions="Center" Margin="0,0,58,0" />
            </Grid>
        </Border>
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="22,18" Spacing="18">
                <Border BackgroundColor="White" Stroke="#DDE6F1" StrokeThickness="1" Padding="20">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="生产卡片信息" TextColor="#00346F" FontSize="16" FontAttributes="Bold" />
                        <BoxView HeightRequest="1" Color="#C8D2DF" />
                        <Grid x:Name="InfoGrid" ColumnDefinitions="*,*" RowSpacing="14" ColumnSpacing="16" />
                    </VerticalStackLayout>
                </Border>
                <Border BackgroundColor="White" StrokeThickness="0" Padding="20">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="16">
                        <Label Text="检验项目录入" TextColor="#051B3D" FontSize="18" FontAttributes="Bold" />
                        <Label Text="圈径控制" TextColor="#051B3D" FontAttributes="Bold" />
                        <Picker x:Name="CoilDiameterPicker" BackgroundColor="#F8FAFD" TextColor="#051B3D" />
                        <Label Text="圈距控制" TextColor="#051B3D" FontAttributes="Bold" />
                        <Picker x:Name="CoilPitchPicker" BackgroundColor="#F8FAFD" TextColor="#051B3D" />
                        <Label Text="实测直径 (mm) *" TextColor="#051B3D" FontAttributes="Bold" />
                        <Entry x:Name="ActualDiameterEntry" Placeholder="输入测量直径" Keyboard="Numeric" BackgroundColor="#F8FAFD" />
                        <Label Text="实测强度 (MPa)" TextColor="#051B3D" FontAttributes="Bold" />
                        <Entry x:Name="StrengthEntry" Placeholder="检测强度值" Keyboard="Numeric" BackgroundColor="#F8FAFD" />
                        <Label Text="延伸率 (%)" TextColor="#051B3D" FontAttributes="Bold" />
                        <Entry x:Name="ElongationEntry" Placeholder="可为空" Keyboard="Numeric" BackgroundColor="#F8FAFD" />
                        <Label Text="表面状态" TextColor="#051B3D" FontAttributes="Bold" />
                        <Entry x:Name="SurfaceEntry" Placeholder="正常" BackgroundColor="#F8FAFD" />
                        <Border BackgroundColor="#EAF4FF" Stroke="#BBD8FF" StrokeThickness="1" Padding="16">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="质检结果" TextColor="#0042AD" FontSize="14" FontAttributes="Bold" />
                                <Picker x:Name="InspectResultPicker" BackgroundColor="#F8FAFD" TextColor="#051B3D" />
                            </VerticalStackLayout>
                        </Border>
                        <Label Text="质检备注" TextColor="#051B3D" FontAttributes="Bold" />
                        <Editor x:Name="MemoEditor" Placeholder="填写其他备注信息..." AutoSize="TextChanges" HeightRequest="90" BackgroundColor="#F8FAFD" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
        <Button Grid.Row="2" Margin="6,16" Text="提交质检" TextColor="#0B3D8B" BackgroundColor="White" BorderColor="#0B3D8B" BorderWidth="1" CornerRadius="10" HeightRequest="54" FontAttributes="Bold" Clicked="OnSubmitClicked" />
    </Grid>
</ContentPage>
