<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JXHLJSApp.Pages.Quality.IncomingQualityScanPage"
             Title="扫码检验"
             BackgroundColor="#F4F6F9"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*,Auto">
        <Border BackgroundColor="#244B88" StrokeThickness="0" Padding="16,22,16,14" HeightRequest="66">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,16,16" /></Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*">
                <Label Text="‹ 取消扫码" TextColor="White" FontSize="15" VerticalOptions="Center">
                    <Label.GestureRecognizers><TapGestureRecognizer Tapped="OnCancelTapped" /></Label.GestureRecognizers>
                </Label>
                <Label Grid.Column="1" Text="扫码检验" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalOptions="Center" Margin="0,0,74,0" />
            </Grid>
        </Border>
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,16" Spacing="18">
                <Border x:Name="ScanPanel" BackgroundColor="#FFFBEF" Stroke="#F59E0B" StrokeThickness="1" StrokeDashArray="4,3" Padding="24" HeightRequest="190">
                    <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnScanPanelTapped" /></Border.GestureRecognizers>
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="📷" FontSize="34" HorizontalTextAlignment="Center" />
                        <Label Text="点击此处模拟扫描 异常物料二维码" TextColor="#D97706" FontSize="15" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Text="状态判断将根据入库单是否提交有所不同" TextColor="#38557C" FontSize="12" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
                <Border x:Name="MaterialInfoCard" BackgroundColor="White" StrokeThickness="0" Padding="18" IsVisible="False">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="扫码识别信息" TextColor="#00346F" FontSize="16" FontAttributes="Bold" />
                        <BoxView HeightRequest="1" Color="#C8D2DF" />
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="二维码编号:" TextColor="#38557C" FontSize="14" />
                            <Label x:Name="QrCodeLabel" Grid.Column="1" TextColor="#051B3D" FontSize="14" FontAttributes="Bold" />
                        </Grid>
                        <Label x:Name="MaterialHintLabel" TextColor="#FF3B4E" FontSize="13" />
                    </VerticalStackLayout>
                </Border>
                <Border BackgroundColor="White" StrokeThickness="0" Padding="18">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="16">
                        <Label Text="异常检验数据录入" TextColor="#051B3D" FontSize="18" FontAttributes="Bold" />
                        <Border BackgroundColor="#EAF4FF" Stroke="#BBD8FF" StrokeThickness="1" Padding="16">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="质检结果" TextColor="#0042AD" FontSize="14" FontAttributes="Bold" />
                                <Picker x:Name="InspectResultPicker" ItemDisplayBinding="{Binding Name}" BackgroundColor="#F8FAFD" TextColor="#051B3D" />
                            </VerticalStackLayout>
                        </Border>
                        <Label Text="问题点 *" TextColor="#051B3D" FontAttributes="Bold" />
                        <Border BackgroundColor="#F8FAFD" Stroke="#DDE5EF" StrokeThickness="1" Padding="14,10">
                            <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnProblemPointTapped" /></Border.GestureRecognizers>
                            <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="ProblemPointLabel" Text="点击选择问题点" TextColor="#7A889A" />
                                <Label Grid.Column="1" Text="▼" TextColor="#8C98AA" />
                            </Grid>
                        </Border>
                        <Label Text="其他问题项" TextColor="#051B3D" FontAttributes="Bold" />
                        <Editor x:Name="OtherProblemEditor" Placeholder="可手动录入其他异常问题，如无请留空" AutoSize="TextChanges" HeightRequest="72" BackgroundColor="#F8FAFD" TextColor="#051B3D" />
                        <Label Text="其他异常说明 *" TextColor="#051B3D" FontAttributes="Bold" />
                        <Editor x:Name="RemarkEditor" Placeholder="如果不合格，请详细说明..." AutoSize="TextChanges" HeightRequest="72" BackgroundColor="#F8FAFD" TextColor="#051B3D" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
        <Button Grid.Row="2" Margin="20,16" Text="保存" TextColor="White" BackgroundColor="#1E427C" CornerRadius="10" HeightRequest="56" FontAttributes="Bold" Clicked="OnSaveClicked" />
    </Grid>
</ContentPage>
