<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JXHLJSApp.Pages.Quality.IncomingQualityScanPage"
             Title="扫码检验"
             BackgroundColor="#F4F6F9"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*,Auto">
        <Border BackgroundColor="#244B88" StrokeThickness="0" Padding="16,22,16,14" HeightRequest="66">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,16,16" /></Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*">
                <Label Text="‹ 取消扫码" TextColor="White" FontSize="15" VerticalOptions="Center">
                    <Label.GestureRecognizers><TapGestureRecognizer Tapped="OnCancelTapped" /></Label.GestureRecognizers>
                </Label>
                <Label Grid.Column="1" Text="扫码检验" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalOptions="Center" Margin="0,0,74,0" />
            </Grid>
        </Border>
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,16" Spacing="18">
                <Border x:Name="ScanPanel" BackgroundColor="#FFFBEF" Stroke="#F59E0B" StrokeThickness="1" StrokeDashArray="4,3" Padding="24" HeightRequest="190">
                    <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnScanPanelTapped" /></Border.GestureRecognizers>
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="📷" FontSize="34" HorizontalTextAlignment="Center" />
                        <Label Text="点击此处模拟扫描 异常物料二维码" TextColor="#D97706" FontSize="15" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Text="状态判断将根据入库单是否提交有所不同" TextColor="#38557C" FontSize="12" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
                <Border x:Name="MaterialInfoCard" BackgroundColor="White" StrokeThickness="0" Padding="18" IsVisible="False">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="物料解析明细" TextColor="#00346F" FontSize="16" FontAttributes="Bold" />
                        <BoxView HeightRequest="1" Color="#C8D2DF" />
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="10">
                            <Label Text="二维码编号:" TextColor="#38557C" FontSize="14" />
                            <Label x:Name="QrCodeLabel" Grid.Column="1" TextColor="#C95F00" FontSize="14" FontAttributes="Bold" />

                            <Label Grid.Row="1" Text="归属入库单:" TextColor="#38557C" FontSize="14" />
                            <Label x:Name="InstockNoLabel" Grid.Row="1" Grid.Column="1" TextColor="#051B3D" FontSize="14" FontAttributes="Bold" />

                            <Label Grid.Row="2" Text="物料名称:" TextColor="#38557C" FontSize="14" />
                            <Label x:Name="MaterialNameLabel" Grid.Row="2" Grid.Column="1" TextColor="#051B3D" FontSize="14" FontAttributes="Bold" />

                            <Label Grid.Row="3" Text="规格参数:" TextColor="#38557C" FontSize="14" />
                            <Label x:Name="SpecLabel" Grid.Row="3" Grid.Column="1" TextColor="#0042AD" FontSize="14" FontAttributes="Bold" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
                <Border BackgroundColor="White" StrokeThickness="0" Padding="18">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14" /></Border.StrokeShape>
                    <VerticalStackLayout Spacing="16">
                        <Label Text="异常检验数据录入" TextColor="#051B3D" FontSize="18" FontAttributes="Bold" />
                        <Border BackgroundColor="#EAF4FF" Stroke="#BBD8FF" StrokeThickness="1" Padding="16">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Label Text="质检结果" TextColor="#0042AD" FontSize="14" FontAttributes="Bold" />
                                <Grid>
                                    <Border x:Name="InspectResultSelector" BackgroundColor="#FFFFFF" Stroke="#1E427C" StrokeThickness="1.5" Padding="20,0" HeightRequest="52">
                                        <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnInspectResultTapped" /></Border.GestureRecognizers>
                                        <Border.StrokeShape><RoundRectangle CornerRadius="9" /></Border.StrokeShape>
                                        <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                                <Label x:Name="InspectResultIconLabel" Text="✕" TextColor="#FF3B4E" FontSize="24" FontAttributes="Bold" VerticalTextAlignment="Center" />
                                                <Label x:Name="InspectResultLabel" Text="请选择" TextColor="#FF3B4E" FontSize="16" FontAttributes="Bold" VerticalTextAlignment="Center" />
                                            </HorizontalStackLayout>
                                            <Label Grid.Column="1" Text="⌄" TextColor="#FF3B4E" FontSize="20" FontAttributes="Bold" VerticalTextAlignment="Center" />
                                        </Grid>
                                    </Border>
                                    <Border x:Name="InspectResultDropdown" IsVisible="False" Margin="0,52,0,0" BackgroundColor="#FFFFFF" Stroke="#DDE5EF" StrokeThickness="1" Padding="0" ZIndex="10">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="0" /></Border.StrokeShape>
                                        <VerticalStackLayout x:Name="InspectResultOptionsLayout" Spacing="0" />
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                        <Label Text="问题点 *" TextColor="#051B3D" FontAttributes="Bold" />
                        <Border BackgroundColor="#F8FAFD" Stroke="#DDE5EF" StrokeThickness="1" Padding="14,10">
                            <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnProblemPointTapped" /></Border.GestureRecognizers>
                            <Border.StrokeShape><RoundRectangle CornerRadius="10" /></Border.StrokeShape>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="ProblemPointLabel" Text="点击选择问题点" TextColor="#7A889A" />
                                <Label Grid.Column="1" Text="▼" TextColor="#8C98AA" />
                            </Grid>
                        </Border>
                        <Label Text="其他问题项" TextColor="#051B3D" FontAttributes="Bold" />
                        <Editor x:Name="OtherProblemEditor" Placeholder="可手动录入其他异常问题，如无请留空" AutoSize="TextChanges" HeightRequest="72" BackgroundColor="#F8FAFD" TextColor="#051B3D" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
        <Button Grid.Row="2" Margin="20,16" Text="保存" TextColor="White" BackgroundColor="#1E427C" CornerRadius="10" HeightRequest="56" FontAttributes="Bold" Clicked="OnSaveClicked" />

        <Grid x:Name="ProblemPointSheetOverlay" Grid.RowSpan="3" IsVisible="False" BackgroundColor="#9905142D" ZIndex="20" RowDefinitions="*,Auto">
            <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnProblemPointSheetBackdropTapped" /></Grid.GestureRecognizers>
            <Border Grid.Row="1" BackgroundColor="White" Padding="20,22,20,16">
                <Border.GestureRecognizers><TapGestureRecognizer /></Border.GestureRecognizers>
                <Border.StrokeShape><RoundRectangle CornerRadius="20,20,0,0" /></Border.StrokeShape>
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,14">
                        <Label Text="选择问题点" TextColor="#001431" FontSize="18" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="×" TextColor="#8C98AA" FontSize="28" VerticalTextAlignment="Center">
                            <Label.GestureRecognizers><TapGestureRecognizer Tapped="OnProblemPointSheetCancelTapped" /></Label.GestureRecognizers>
                        </Label>
                    </Grid>
                    <BoxView HeightRequest="1" Color="#DDE5EF" />
                    <ScrollView MaximumHeightRequest="282">
                        <VerticalStackLayout x:Name="ProblemPointOptionsLayout" Spacing="0" />
                    </ScrollView>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,20,0,0">
                        <Button Text="取消" TextColor="#051B3D" BackgroundColor="White" BorderColor="#D1D9E6" BorderWidth="1" CornerRadius="10" HeightRequest="56" FontAttributes="Bold" Clicked="OnProblemPointSheetCancelClicked" />
                        <Button Grid.Column="1" Text="确认选择" TextColor="White" BackgroundColor="#1E427C" CornerRadius="10" HeightRequest="56" FontAttributes="Bold" Clicked="OnProblemPointSheetConfirmClicked" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
